{
  "name": "@payai/agentic-payments",
  "version": "0.1.6",
  "description": "Accept x402 and MPP agentic payments through a single integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "default": "./dist/middleware/express.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "attw": "attw --pack . --ignore-rules cjs-resolves-to-esm no-resolution",
    "size": "size-limit",
    "check": "npm run typecheck && npm run lint && npm run publint && npm run attw && npm run size",
    "prepublishOnly": "npm run build && npm run check"
  },
  "dependencies": {
    "@x402/core": "^2.7.0",
    "mppx": "^0.4.0"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "viem": ">=2.39.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.12",
    "@size-limit/file": "^12.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "publint": "^0.3.18",
    "size-limit": "^12.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PayAINetwork/agentic-payments"
  },
  "license": "MIT",
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "2 KB"
    },
    {
      "path": "dist/middleware/express.js",
      "limit": "10 KB"
    }
  ]
}
