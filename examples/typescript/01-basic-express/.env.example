# Copy to .env and edit. All values optional — defaults work for a local demo.

# test  = testnet chains, no real funds needed (default)
# live  = mainnet chains, real payments
MODE=test

# Port to listen on
PORT=4000

# Receiver wallets — replace with your own before switching MODE=live.
# EVM address receives on Base + Tempo.
PAY_TO_EVM=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
# Solana address receives on Solana mainnet / devnet (matched to MODE).
PAY_TO_SVM=ExamP1eWaLLet1111111111111111111111111111111
