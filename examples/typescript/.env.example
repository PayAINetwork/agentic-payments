# Copy this file to .env and fill in your values.
# Used by: npm run pay:mpp, npm run pay:x402, npm run probe

# Target URL (defaults to http://localhost:4000/weather)
# URL=http://localhost:4000/weather

# Network filter for pay:x402 — substring or exact CAIP-2 match against the accepts list.
# EVM examples:  "eip155:84532" (Base Sepolia), "eip155:80002" (Polygon Amoy), "eip155:43113" (Avalanche Fuji)
# SVM examples:  "solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1" (devnet), "solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp" (mainnet)
# Partial match also works: "solana" matches both SVM networks; "80002" matches Polygon Amoy.
# NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1

# EVM private key (hex, 0x-prefixed).
# Used by:
#   pay:mpp  — Tempo testnet account with pathUSD (chainId 42431)
#   pay:x402 — Any supported EVM testnet account with USDC
#              (Base Sepolia / Polygon Amoy / Avalanche Fuji / etc.)
# EVM_PRIVATE_KEY=0x...

# Solana private key (base58-encoded 64-byte keypair, e.g. Phantom "export private key").
# Used by:
#   pay:x402 — Solana devnet account with USDC
# SVM_PRIVATE_KEY=...

# ── Solana ATA requirement ─────────────────────────────────────────────────────
# Unlike EVM, the PAY_TO_SVM address must have an existing USDC Associated Token
# Account (ATA) or the facilitator's settlement transaction will fail. EVM has no
# equivalent constraint — any address can receive USDC.
#
# If you set PAY_TO_SVM to your own wallet, create the ATA first:
#   devnet:  spl-token create-account 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU <YOUR_ADDR> --url devnet
#   mainnet: spl-token create-account EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v <YOUR_ADDR>
# PAY_TO_SVM=H32YnqbzL62YkHMSCzfKcLry9yuipwwx1EMztiCSPhjb
