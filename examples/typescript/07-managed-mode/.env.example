# Copy this file to .env and fill in your values.

# ── Required ───────────────────────────────────────────────────────────────────

# API key from the PayAI dashboard (Dashboard → Settings → API Keys).
# PAYAI_KEY_ID=cmp...
# PAYAI_SK=payai_sk_...

# ── Recommended ────────────────────────────────────────────────────────────────

# Public URL of this server. The portal uses it to prefill the "Server URL"
# field in the Endpoints onboarding step so it can test your routes directly.
# Without this the portal's Test buttons will have no URL to probe.
#
# For local dev, use a public tunnel (ngrok, Cloudflare Tunnel, etc.) rather
# than http://localhost — the portal runs in a browser and can't reach localhost
# on your machine.
#
#   ngrok:             ngrok http 4000  →  copy the https://....ngrok-free.app URL
#   Cloudflare Tunnel: cloudflared tunnel --url http://localhost:4000
#
# SERVER_URL=https://your-server.example.com

# ── Optional ───────────────────────────────────────────────────────────────────

# Override the PayAI portal URL (defaults to https://merchant.payai.network).
# Set to http://localhost:3000 when running the portal locally.
# PAYAI_API_URL=https://merchant.payai.network

# Port to listen on (default: 4000).
# PORT=4000
